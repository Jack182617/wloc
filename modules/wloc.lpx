#!name=Apple WLOC 定位修改
#!desc=修改 Apple 网络定位返回坐标 | 选点页面: https://wloc-jack182617.yuanjie182617.workers.dev/
#!icon=https://raw.githubusercontent.com/Jack182617/wloc/ffde056/wloc.jpg
#!author=Yu9191 Rewrite
#!homepage=https://github.com/Jack182617/wloc
#!openUrl=https://wloc-jack182617.yuanjie182617.workers.dev/

[Argument]
longitude = input, "113.94114", tag=经度(在线选点优先)
latitude = input, "22.544577", tag=纬度(在线选点优先)
accuracy = input, "25", tag=精度(米)
logLevel = select, "info", "off", "error", "warn", "debug", "all", tag=日志级别

[Script]
http-response ^https?:\/\/gs-loc(-cn)?\.apple\.com\/clls\/wloc script-path=https://raw.githubusercontent.com/Jack182617/wloc/ffde056/dist/wloc.js, requires-body=true, binary-body-mode=true, timeout=30, tag=Apple WLOC, argument=[{longitude},{latitude},{accuracy},{logLevel}]
http-request ^https?:\/\/gs-loc(-cn)?\.apple\.com\/wloc-settings\/save script-path=https://raw.githubusercontent.com/Jack182617/wloc/ffde056/dist/wloc-settings.js, timeout=10, tag=WLOC Settings

[MITM]
hostname = gs-loc.apple.com, gs-loc-cn.apple.com
